# .env.example
# Turso Database Configuration (Keep server-side only)
TURSO_DB_URL=libsql://your-database-slug.turso.io
TURSO_DB_TOKEN=your-long-secure-access-token

# Cryptographic Session Signer Secret
SESSION_SECRET=some-long-random-string-for-hmac-sessions

# Optional integrations (Firebase push notifications / admin auth)
FIREBASE_SERVICE_ACCOUNT_PATH=
